def primera_fila_datos(df):
    """
    Detecta la primera fila no completamente vacía.
    Vectorizado: ~50x más rápido que iterrows() en hojas grandes.
    """
    if df.empty:
        return 0
    mask = df.notna().any(axis=1)
    if not mask.any():
        return 0
    return int(mask.idxmax())


def _aplicar_encabezado(df_raw, hr):
    """
    Asigna encabezado a un DataFrame crudo sin releer el archivo.
    Elimina la tercera lectura con pd.read_excel.
    """
    if df_raw is None or df_raw.empty:
        return df_raw
    df = df_raw.iloc[hr:].reset_index(drop=True) if hr > 0 else df_raw.copy()
    if df.empty:
        return df
    nuevos_cols = [
        str(v).strip() if (v is not None and str(v).strip() != "") else f"Col_{i}"
        for i, v in enumerate(df.iloc[0])
    ]
    df.columns = nuevos_cols
    df = df.iloc[1:].reset_index(drop=True)

    # Inferir tipos: openpyxl read_only devuelve todo como object con valores
    # Python nativos (int, float, str, datetime). infer_objects() + conversión
    # explícita de datetime evita errores en analizar_df.
    try:
        df = df.infer_objects()
        for col in df.columns:
            if df[col].dtype == object:
                # Intentar convertir a numérico primero
                convertida = pd.to_numeric(df[col], errors="coerce")
                if convertida.notna().sum() / max(df[col].notna().sum(), 1) > 0.8:
                    df[col] = convertida
                else:
                    # Intentar convertir a datetime
                    try:
                        convertida_dt = pd.to_datetime(df[col], errors="coerce",
                                                       infer_datetime_format=True)
                        if convertida_dt.notna().sum() / max(df[col].notna().sum(), 1) > 0.8:
                            df[col] = convertida_dt
                    except Exception:
                        pass
    except Exception:
        pass
    return df


def _hoja_vacia():
    return {"vacia":True,"filas_totales":0,"filas_con_datos":0,"filas_en_blanco":0,
            "num_columnas":0,"nombres_columnas":[],"pct_columnas_limpias":0.0,
            "pct_nulos":{},"tipos":{},"columnas_mixtas":[],"fila_encabezado":0,
            "encabezado_en_fila1":True}

def analizar_df(df, nombre_hoja=""):
    if df is None or df.empty or df.dropna(how="all").empty:
        return {**_hoja_vacia(), "nombre":nombre_hoja}
    df_sin = df.dropna(how="all")
    cols   = [str(c) for c in df.columns]
    limpias= sum(1 for c in cols
                 if not c.startswith("Unnamed") and c.strip()!="" and
                    not re.search(r"[^a-zA-Z0-9áéíóúÁÉÍÓÚñÑüÜ _\-./()]",c))
    tipos, mixtas = {}, []
    for col in df.columns:
        s  = df[col].dropna()
        if s.empty: tipos[str(col)]="vacío"; continue
        try:
            tp = str(df[col].dtype)
        except Exception:
            tp = "object"
        if "int" in tp or "float" in tp:   tipos[str(col)]="numérico"
        elif "datetime" in tp:             tipos[str(col)]="fecha"
        elif "bool"     in tp:             tipos[str(col)]="booleano"
        else:
            try:
                n = pd.to_numeric(s, errors="coerce").notna().sum()
                t = s.apply(lambda x: isinstance(x, str)).sum()
                if n > 0 and t > 0: tipos[str(col)]="mixto"; mixtas.append(str(col))
                else:               tipos[str(col)]="texto"
            except Exception:
                tipos[str(col)]="texto"

    # isnull robusto: algunos dtypes object con datetimes nativos pueden fallar
    try:
        pct_nulos = df.isnull().mean().mul(100).round(1).to_dict()
    except Exception:
        pct_nulos = {}
        for col in df.columns:
            try:
                pct_nulos[str(col)] = round(df[col].isnull().mean() * 100, 1)
            except Exception:
                pct_nulos[str(col)] = 0.0
    return {"vacia":False,"nombre":nombre_hoja,
            "filas_totales":df.shape[0],"filas_con_datos":df_sin.shape[0],
            "filas_en_blanco":df.shape[0]-df_sin.shape[0],
            "num_columnas":len(cols),"nombres_columnas":cols,
            "pct_columnas_limpias":round(limpias/max(len(cols),1)*100,1),
            "pct_nulos":pct_nulos,
            "tipos":tipos,"columnas_mixtas":mixtas}


