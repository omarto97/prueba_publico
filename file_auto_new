#  SCORING
# ══════════════════════════════════════════════════════════════════

def calcular_score(niveles):
    score_d = {}
    techo   = 100
    bloqueo = None

    peso_ef = sum(REGLAS[c]["peso"] for c,n in niveles.items()
                  if n is not None and c in REGLAS)
    if peso_ef == 0:
        return {c:None for c in REGLAS}, 0, "⛔ No evaluable", None

    for cod, cfg in REGLAS.items():
        n = niveles.get(cod)
        if n is None:
            score_d[cod] = None; continue
        max_n = cfg["max_nivel_normal"]
        if n == 10 and cfg["bloqueo"]:
            score_d[cod] = 0.0
            if cfg["techo"] is not None and cfg["techo"] < techo:
                techo   = cfg["techo"]
                bloqueo = cod
        else:
            frac = 1.0 - min(n, max_n) / max_n
            score_d[cod] = round(frac * cfg["peso"] / PESO_TOTAL_RAW * 100, 2)

    base   = sum(v for v in score_d.values() if v is not None)
    factor = PESO_TOTAL_RAW / max(peso_ef, 1)
    base   = min(round(base * factor, 1), 100)
    final  = min(base, techo)

    if   final >= 85: cat = "🟢 Automatizable"
    elif final >= 65: cat = "🟡 Automatizable con controladores"
    elif final >= 40: cat = "🟠 Automatizable con esfuerzo"
    elif final >= 20: cat = "🔴 Difícil"
    else:             cat = "⛔ No automatizable"

    return score_d, final, cat, bloqueo


