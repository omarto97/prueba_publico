        _hdr(ws.cell(12, j+6), "9C1B1B")
        ws.cell(12, j+6).value = h
    for i, (sc, cat, r) in enumerate(reversed(ordenados[-5:]), 13):
        _, _, _, blq = calcular_score(r["niveles"])
        vals = [r["archivo"][:40], r["grupo"], sc, cat, blq or ""]
        for j, v in enumerate(vals, 1):
            _cel(ws.cell(i, j+6), v, bg=COLORES_CAT.get(cat,"FFFFFF"),
                 h="left" if j==1 else "center")

    # ── Score por grupo (fila 20+) ────────────────────────────────
