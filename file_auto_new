        row = 4 + i
        ws.merge_cells(f"A{row}:B{row}")
        _cel(ws[f"A{row}"], label, bold=True, h="left", sz=10)
        ws.merge_cells(f"C{row}:D{row}")
        _cel(ws[f"C{row}"], val, bold=True, color=color, sz=14, h="center")

    # ── Distribución por categoría (fila 4-9, cols F-H) ──────────
    ws.merge_cells("F3:H3")
    _hdr(ws["F3"], "2E4057")
