def main():
    if not os.path.isdir(CARPETA_RAIZ):
        print(f"❌  Carpeta no encontrada: {CARPETA_RAIZ}")
        sys.exit(1)

    print(f"\n🔍  Escaneando: {os.path.abspath(CARPETA_RAIZ)}\n")
    encontrados = descubrir_archivos(CARPETA_RAIZ)

    directos = [f for f in encontrados if f["tipo"] == "datos"]
    correos  = [f for f in encontrados if f["tipo"] == "correo"]
    print(f"   Archivos de datos : {len(directos)}")
    print(f"   Correos .msg      : {len(correos)}\n")

    # Inferir grupos y construir índice
    grupos_rutas = defaultdict(list)   # grupo → [rutas]
    for item in directos:
        g = inferir_grupo(item["ruta"], item["subcarpeta"])
        item["grupo"] = g
        grupos_rutas[g].append(item["ruta"])

    resultados, adjuntos_all, errores = [], [], []
    total = len(directos) + len(correos)

    # ── Archivos directos ─────────────────────────────────────────
    for i, item in enumerate(directos, 1):
        nombre = os.path.basename(item["ruta"])
        print(f"  [{i:>4}/{total}] {nombre[:65]:<65}", end=" ", flush=True)
        ctx = grupos_rutas.get(item["grupo"], [])
        r   = analizar_archivo(item, ctx_grupo=ctx)

        if r["error_lectura"] and not r["hojas"]:
            errores.append({"archivo":nombre,"ruta":item["ruta"],
                            "formato":r.get("formato","?"),"error":r["error_lectura"]})
            print(f"❌  {r['error_lectura'][:55]}")
        else:
            msg = f"✔   {r['num_hojas']} hoja(s)"
            if r["error_lectura"]: msg += f"  ⚠️ {r['error_lectura'][:30]}"
            if r["tiene_pwd"]:     msg += "  🔒 contraseña"
            print(msg)
            resultados.append(r)

    # ── Correos .msg ──────────────────────────────────────────────
    for i, item in enumerate(correos, len(directos)+1):
        nombre = os.path.basename(item["ruta"])
        print(f"  [{i:>4}/{total}] 📧 {nombre[:62]:<62}", end=" ", flush=True)

        adj_info, datos_ext, err_msg = extraer_adjuntos_msg(item["ruta"])
        if err_msg and not adj_info:
            errores.append({"archivo":nombre,"ruta":item["ruta"],
                            "formato":"msg","error":err_msg})
            print(f"❌  {err_msg[:55]}")
            continue

        adjuntos_all.extend(adj_info)
        print(f"✔   {len(adj_info)} adjuntos ({sum(1 for a in adj_info if a['es_dato'])} datos)")

        for nombre_adj, ext_adj, bytes_adj, asunto, remit, fecha in datos_ext:
            print(f"         ↳ {nombre_adj[:60]:<60}", end=" ", flush=True)
            sub_item = {"ruta":None, "nombre_display":nombre_adj, "bytes":bytes_adj,
                        "subcarpeta":item["subcarpeta"], "correo_padre":nombre,
                        "asunto_correo":asunto, "remitente":remit, "fecha_correo":fecha,
                        "grupo":inferir_grupo(nombre_adj, item["subcarpeta"])}
            r = analizar_archivo(sub_item)
            if r["error_lectura"] and not r["hojas"]:
                errores.append({"archivo":nombre_adj,"ruta":f"(en {nombre})",
                                "formato":ext_adj,"error":r["error_lectura"]})
                print(f"❌  {r['error_lectura'][:45]}")
            else:
                print(f"✔   {r['num_hojas']} hoja(s)")
                resultados.append(r)

    # ── Recalcular regla E por grupo ──────────────────────────────
    grupos_rs = defaultdict(list)
    for r in resultados: grupos_rs[r["grupo"]].append(r)
    recalcular_E_por_grupo(grupos_rs)

    # ── Exportar ──────────────────────────────────────────────────
    print(f"\n📊  Generando reporte ({len(resultados)} archivos)...")
    exportar(resultados, adjuntos_all, grupos_rutas, errores, ARCHIVO_SALIDA)

    # Resumen final en consola
    cats = defaultdict(int)
    scores = []
    for r in resultados:
        _, s, c, _ = calcular_score(r.get("niveles",{}))
        scores.append(s); cats[c] += 1

    print(f"\n{'─'*58}")
    print(f"  Archivos analizados  : {len(resultados)}")
    print(f"  Archivos con error   : {len(errores)}")
    if scores:
        print(f"  Score promedio       : {round(sum(scores)/len(scores),1)}")
        print(f"  Score máximo         : {max(scores)}")
        print(f"  Score mínimo         : {min(scores)}")
    print()
    for cat in COLORES_CAT:
        if cats[cat]:
            print(f"  {cat:<42}: {cats[cat]}")
    print(f"{'─'*58}\n")


if __name__ == "__main__":
    main()
