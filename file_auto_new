def detectar_encoding(datos_bytes=None, ruta=None):
    try:
        muestra = datos_bytes[:50_000] if datos_bytes else open(ruta,"rb").read(50_000)
        enc = chardet.detect(muestra).get("encoding") or "utf-8"
        return enc.replace("ISO-8859-1","latin-1").replace("Windows-1252","cp1252")
    except Exception:
        return "utf-8"

def detectar_sep(texto, n=5):
    lineas = [l for l in texto.splitlines()[:n] if l.strip()]
    if not lineas: return ","
    mejor, mc = ",", 0
    for sep in [",","\t",";","|"]:
        cnt = [len(l.split(sep)) for l in lineas]
        if len(set(cnt))==1 and cnt[0] > mc:
            mc, mejor = cnt[0], sep
    return mejor

def leer_csv_txt(ruta=None, datos_bytes=None):
    enc  = detectar_encoding(datos_bytes=datos_bytes, ruta=ruta)
    txt  = (datos_bytes.decode(enc,errors="replace") if datos_bytes
            else open(ruta,"r",encoding=enc,errors="replace").read())
    sep  = detectar_sep(txt)
    df   = pd.read_csv(io.StringIO(txt), sep=sep, dtype=str, on_bad_lines="skip")
    return df, sep, enc


