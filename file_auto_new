# ══════════════════════════════════════════════════════════════════

def exportar(resultados, adjuntos, grupos, errores, ruta_salida):
    wb = openpyxl.Workbook()
    wb.remove(wb.active)

    # Forzar recálculo automático al abrir en Excel
    wb.calculation.calcMode = "auto"

    hoja_dashboard(wb, resultados)
    hoja_scoring(wb, resultados)
    hoja_resumen(wb, resultados)
    hoja_nulos(wb, resultados)
    hoja_adjuntos(wb, adjuntos)
    hoja_grupos(wb, grupos)
    hoja_referencia(wb)
    hoja_errores(wb, errores)

    wb.save(ruta_salida)
    print(f"\n✅  Reporte guardado: {os.path.abspath(ruta_salida)}")


