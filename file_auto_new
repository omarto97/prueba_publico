    # ── Top 5 más automatizables (fila 12+) ──────────────────────
    ordenados = sorted(scores_cats, key=lambda x: x[0], reverse=True)
    ws.merge_cells("A11:E11")
    _hdr(ws["A11"], "1A7A4A")
    ws["A11"].value = "🏆  Top 5 más automatizables"
    for j,h in enumerate(["Archivo","Grupo","Score","Categoría","Formato"],1):
        _hdr(ws.cell(12, j), "2E7D32")
        ws.cell(12, j).value = h
    for i, (sc, cat, r) in enumerate(ordenados[:5], 13):
        vals = [r["archivo"][:40], r["grupo"], sc, cat, r["formato"]]
        for j, v in enumerate(vals, 1):
            _cel(ws.cell(i, j), v, bg=COLORES_CAT.get(cat,"FFFFFF"), h="left" if j==1 else "center")

    # ── Top 5 menos automatizables (fila 12+, cols G-K) ──────────
