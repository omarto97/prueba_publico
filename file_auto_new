def tiene_kw(texto, lista_kw):
    t = str(texto).lower()
    return any(re.search(kw, t, re.IGNORECASE) for kw in lista_kw)

def fecha_en_nombre(texto):
    t = str(texto).lower()
    return any(re.search(p, t, re.IGNORECASE) for p in RE_FECHA_NOMBRE)

def meta_os(ruta):
    try:
        s = os.stat(ruta)
        fmt = lambda ts: datetime.datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M")
        return {"mtime": fmt(s.st_mtime), "size_kb": round(s.st_size / 1024, 1)}
    except Exception:
        return {"mtime": None, "size_kb": None}

def es_contrasena_error(msg):
    msg = str(msg).lower()
    return any(x in msg for x in ["password","encrypted","proteg","contraseña",
                                   "decrypt","workbook is encrypted"])


