#  REGLA E: CONSISTENCIA POR GRUPO
# ══════════════════════════════════════════════════════════════════

def recalcular_E_por_grupo(grupos):
    for grupo, archivos in grupos.items():
        esquemas = []
        for ar in archivos:
            for h in ar["hojas"]:
                if not h["vacia"]:
                    esquemas.append(frozenset(h["nombres_columnas"]))

        if not esquemas or len(archivos) == 1:
            # Archivo único: marcar como "no evaluable por grupo"
            for ar in archivos:
                if ar["niveles"].get("E") is None:
                    vls = [h["pct_columnas_limpias"] for h in ar["hojas"] if not h["vacia"]]
                    p   = sum(vls)/len(vls) if vls else 0
                    ar["niveles"]["E"] = 1 if p>=80 else (3 if p>=40 else 10)
            continue

        ref = esquemas[0]
        sims = [len(e & ref)/max(len(e | ref),1) for e in esquemas]
        sim  = sum(sims)/len(sims)

        for ar in archivos:
            if   sim >= 0.95: ar["niveles"]["E"] = 1
            elif sim >= 0.80: ar["niveles"]["E"] = 2
            elif sim >= 0.50: ar["niveles"]["E"] = 3
            else:             ar["niveles"]["E"] = 10


