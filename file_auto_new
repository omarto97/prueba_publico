def analizar_archivo(item, ctx_grupo=None):
    ruta         = item.get("ruta")
    nombre       = item.get("nombre_display") or (os.path.basename(ruta) if ruta else "?")
    ext          = os.path.splitext(nombre)[1].lower()
    es_csv       = ext in (".csv",".txt")
    datos_bytes  = item.get("bytes")
    correo_padre = item.get("correo_padre","")
    asunto       = item.get("asunto_correo","")
    remit        = item.get("remitente","")
    fecha_correo = item.get("fecha_correo","")
    meta         = meta_os(ruta) if ruta else {"mtime":None,"size_kb":None}
    grupo        = item.get("grupo","SIN_GRUPO")

    r = {"archivo":nombre, "ruta":ruta or "(en correo)", "subcarpeta":item.get("subcarpeta",""),
         "grupo":grupo, "formato":ext.lstrip("."), "origen":"adjunto" if correo_padre else "directo",
         "correo_padre":correo_padre, "asunto_correo":asunto, "remitente":remit,
         "fecha_correo":fecha_correo, "mtime":meta["mtime"],
         "tamanio_kb":len(datos_bytes)/1024 if datos_bytes else meta["size_kb"],
         "num_hojas":0, "total_formulas":0, "fusionadas":0,
         "tiene_pivot":False, "tiene_table":False, "tiene_pwd":False,
         "hojas":[], "separador":"N/A", "encoding":"N/A",
         "error_lectura":None, "niveles":{}, "niveles_auto":{}}

    # ── LEER ─────────────────────────────────────────────────────
    hojas_raw = {}
    if es_csv:
        try:
            df, sep, enc = leer_csv_txt(ruta=ruta if not datos_bytes else None,
                                        datos_bytes=datos_bytes)
            hojas_raw = {"datos": df}
            r.update({"separador":repr(sep),"encoding":enc,"num_hojas":1})
        except Exception as e:
            r["error_lectura"] = str(e)
    else:
        res = leer_excel(ruta)  # retorna 7 valores
        hojas_raw,fml,fus,piv,tbl,err,tiene_pwd = res
        r.update({"total_formulas":fml,"fusionadas":fus,"tiene_pivot":piv,
                  "tiene_table":tbl,"num_hojas":len(hojas_raw),
                  "error_lectura":err,"tiene_pwd":bool(tiene_pwd)})

    # ── ANALIZAR HOJAS ────────────────────────────────────────────
    todos_cols = []
    filas_vacias_max = 0
    hojas_con_datos  = 0

    for nombre_hoja, df_raw in hojas_raw.items():
        if df_raw is None or df_raw.empty:
            r["hojas"].append({**_hoja_vacia(),"nombre":nombre_hoja}); continue

        hr = primera_fila_datos(df_raw)
        filas_vacias_max = max(filas_vacias_max, hr)

        # Asignar encabezado desde el DataFrame ya en memoria (sin releer el archivo)
        try:
            df = _aplicar_encabezado(df_raw, hr)
        except Exception:
            df = df_raw

        m = analizar_df(df, nombre_hoja)
        m["fila_encabezado"]    = int(hr)
        m["encabezado_en_fila1"] = hr == 0
        r["hojas"].append(m)
        if not m["vacia"]:
            hojas_con_datos += 1
            todos_cols.extend(m["nombres_columnas"])

    # ── ESTIMAR NIVELES ───────────────────────────────────────────
    nv, na = {}, {}   # niveles, niveles_auto (True=automático, False=estimado)
    txt = " ".join([nombre, asunto, remit,
                    " ".join(todos_cols), item.get("subcarpeta","")]).lower()

    # A – Fecha de la fuente
    tiene_col_fecha = any(re.search(r"fecha|date|period|mes|month",str(c),re.I)
                          for c in todos_cols)
    if tiene_col_fecha: nv["A"] = 0
    elif fecha_en_nombre(nombre): nv["A"] = 1
    elif fecha_correo:  nv["A"] = 2
    elif meta["mtime"]: nv["A"] = 3
    else:               nv["A"] = 4
    na["A"] = True

    # B – Cod cliente ERP
    if tiene_kw(" ".join(todos_cols), KW_CLIENTE):       nv["B"] = 0
    elif tiene_kw(nombre, KW_CLIENTE) or \
         tiene_kw(asunto, KW_CLIENTE):                   nv["B"] = 1
    elif remit and "@" in remit:                          nv["B"] = 2
    elif grupo != "SIN_GRUPO":                            nv["B"] = 3
    else:                                                 nv["B"] = 4
    na["B"] = False

    # C – Periodo
    tipos_flat = {}
    for h in r["hojas"]: tipos_flat.update(h.get("tipos",{}))
    cols_fecha_tipo = [c for c,t in tipos_flat.items()
                       if t=="fecha" and re.search(r"fecha|date|period|mes|month",str(c),re.I)]
    if cols_fecha_tipo:                nv["C"] = 0
    elif tiene_kw(" ".join(todos_cols),KW_PERIODO) and not cols_fecha_tipo: nv["C"] = 1
    elif fecha_en_nombre(nombre):
        limpio = re.sub(r"[\s_\-]?\d{4}[-_]?\d{0,2}","",nombre)
        nv["C"] = 3 if len(limpio) < len(nombre)*0.6 else 4
    else:                              nv["C"] = 5
    na["C"] = True

    # D – Frecuencia
    if ctx_grupo and len(ctx_grupo) >= 3: nv["D"] = 0
    elif correo_padre:                     nv["D"] = 2
    else:                                  nv["D"] = 1
    na["D"] = False

    # E – Nombres de columnas (placeholder si hay grupo; se recalcula después)
    if ctx_grupo and len(ctx_grupo) > 1:
        nv["E"] = None
    else:
        pct = 0
        vls = [h["pct_columnas_limpias"] for h in r["hojas"] if not h["vacia"]]
        if vls: pct = sum(vls)/len(vls)
        nv["E"] = 1 if pct >= 80 else (3 if pct >= 40 else 10)
    na["E"] = True

    # F – Fuente
    if correo_padre:                      nv["F"] = 2
    elif item.get("subcarpeta",".") != ".": nv["F"] = 1
    else:                                  nv["F"] = 3
    na["F"] = False

    # G – Integridad (con detección de contraseña)
    if r["tiene_pwd"]:                               nv["G"] = 0
    elif r["error_lectura"] and not r["hojas"]:      nv["G"] = 10
    elif r["error_lectura"]:                         nv["G"] = 2
    else:                                            nv["G"] = 1
    na["G"] = True

    # H – Cantidad de hojas
    nh = r["num_hojas"]
    if nh == 1 and hojas_con_datos == 1:             nv["H"] = 0
    elif hojas_con_datos == nh:                      nv["H"] = 1
    elif hojas_con_datos < nh:                       nv["H"] = 2
    else:                                            nv["H"] = 3
    na["H"] = True

    # I – Elementos creados
    if r["tiene_pivot"] and r["tiene_table"]:        nv["I"] = 3
    elif r["tiene_pivot"]:                           nv["I"] = 2
    elif r["tiene_table"]:                           nv["I"] = 1
    elif hojas_con_datos > 0:                        nv["I"] = 0
    else:                                            nv["I"] = 10
    na["I"] = True

    # J – Limpieza tabular
    fus = r["fusionadas"]
    mixtas_total = sum(len(h.get("columnas_mixtas",[])) for h in r["hojas"])
    enc_ok = sum(1 for h in r["hojas"] if not h["vacia"] and h.get("encabezado_en_fila1"))
    nulos_all = [v for h in r["hojas"] if not h["vacia"]
                 for v in h.get("pct_nulos",{}).values()]
    prom_nulos = sum(nulos_all)/max(len(nulos_all),1) if nulos_all else 0

    if filas_vacias_max==0 and fus==0 and mixtas_total==0 and enc_ok==hojas_con_datos:
        nv["J"] = 0 if prom_nulos < 5 else 1
    elif 0 < filas_vacias_max <= 5:  nv["J"] = 2
    elif filas_vacias_max > 5:       nv["J"] = 3
    elif fus > 20:                   nv["J"] = 4
    else:                            nv["J"] = 1
    na["J"] = True

    # K – Normalización
    if fus > 50 or mixtas_total > 5:       nv["K"] = 3
    elif r["tiene_pivot"]:                 nv["K"] = 2
    elif fus > 10 or mixtas_total > 2:     nv["K"] = 1
    else:                                  nv["K"] = 0
    na["K"] = True

    # L – Referencias producto
    d56   = any(re.search(r"\bd56\b",str(c),re.I) for c in todos_cols)
    abbott= any(re.search(r"(cod|ref|sku)[\s_]?(abbott|prod)",str(c),re.I) for c in todos_cols)
    cod_c = any(re.search(r"(cod|ref|sku|item)",str(c),re.I) for c in todos_cols)
    nom_p = tiene_kw(" ".join(todos_cols), KW_PRODUCTO)
    if d56:    nv["L"] = 0
    elif abbott: nv["L"] = 1
    elif cod_c:  nv["L"] = 2
    elif nom_p:  nv["L"] = 3
    else:        nv["L"] = 4
    na["L"] = False

    # M – Unidades
    cu = [c for c in todos_cols if tiene_kw(str(c), KW_UNIDAD)]
    if len(cu) == 1:                       nv["M"] = 0
    elif len(cu) > 1:                      nv["M"] = 1
    elif any(re.search(r"uom|unidad_medida|unit_measure",str(c),re.I)
             for c in todos_cols):         nv["M"] = 2
    else:                                  nv["M"] = 3
    na["M"] = False

    # N – Propósito
    en_col  = tiene_kw(" ".join(todos_cols), KW_VENTAS+KW_INVENTARIO+KW_IMS)
    en_nom  = tiene_kw(nombre+asunto, KW_VENTAS+KW_INVENTARIO+KW_IMS)
    if en_col and en_nom:  nv["N"] = 0
    elif en_col:           nv["N"] = 1
    else:                  nv["N"] = 2
    na["N"] = True

    # O – Valor monetario
    cv = [c for c in todos_cols if tiene_kw(str(c), KW_VALOR)]
    tm = tiene_kw(txt, KW_MONEDA)
    if len(cv)==1 and tm:   nv["O"] = 0
    elif len(cv)>1 and tm:  nv["O"] = 1
    elif cv and not tm:     nv["O"] = 2
    else:                   nv["O"] = 3
    na["O"] = False

    r["niveles"]      = nv
    r["niveles_auto"] = na
    return r


