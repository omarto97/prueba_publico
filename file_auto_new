EXT_DATOS  = {".xls",".xlsx",".xlsm",".xlsb",".csv",".txt"}
EXT_CORREO = {".msg"}

def descubrir_archivos(raiz):
    items = []
    for dirpath, _, filenames in os.walk(raiz):
        for fn in filenames:
            if fn.startswith("~$"): continue
            ext  = os.path.splitext(fn)[1].lower()
            ruta = os.path.join(dirpath, fn)
            sub  = os.path.relpath(dirpath, raiz)
            if ext in EXT_DATOS:
                items.append({"ruta":ruta,"tipo":"datos","subcarpeta":sub,"correo_padre":None})
            elif ext in EXT_CORREO:
                items.append({"ruta":ruta,"tipo":"correo","subcarpeta":sub,"correo_padre":None})
    return items


