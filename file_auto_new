def extraer_adjuntos_msg(ruta_msg):
    try:
        import extract_msg
    except ImportError:
        return [], [], "Instala extract-msg: pip install extract-msg"
    adj_info, datos_ext = [], []
    try:
        msg = extract_msg.Message(ruta_msg)
        asunto = msg.subject or "(sin asunto)"
        remit  = msg.sender  or "?"
        fecha  = str(msg.date or "?")
        for att in msg.attachments:
            nombre = att.longFilename or att.shortFilename or "adjunto"
            ext    = os.path.splitext(nombre)[1].lower()
            datos  = att.data if hasattr(att,"data") else None
            es_d   = ext in EXT_DATOS
            adj_info.append({"correo":os.path.basename(ruta_msg),"ruta_correo":ruta_msg,
                             "asunto":asunto,"remitente":remit,"fecha_correo":fecha,
                             "adjunto":nombre,"extension":ext,
                             "tamanio_kb":round(len(datos)/1024,1) if datos else None,
                             "es_dato":es_d})
            if es_d and datos:
                datos_ext.append((nombre, ext, datos, asunto, remit, fecha))
        msg.close()
    except Exception as e:
        return [], [], str(e)
    return adj_info, datos_ext, None


