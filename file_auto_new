def hoja_scoring(wb, resultados):
    ws = wb.create_sheet("SCORING")
    ws.sheet_view.showGridLines = False
    ws.freeze_panes = "D3"

    # Instrucciones
    last_col = get_column_letter(8 + len(REGLAS) * 2)
    ws.merge_cells(f"A1:{last_col}1")
    ws["A1"].value = (
        "⚠️  INSTRUCCIONES: Columnas en AMARILLO = estimadas automáticamente — "
        "verifica y corrige el nivel en la columna 'Override' correspondiente. "
        "El Score Final recalcula automáticamente al modificar cualquier Override. "
        "Niveles válidos: ver hoja REFERENCIA."
    )
    ws["A1"].font      = Font(bold=True, italic=True, color="7F3F00", name="Arial", size=9)
    ws["A1"].fill      = PatternFill("solid", fgColor="FFF2CC")
    ws["A1"].alignment = Alignment(wrap_text=True, horizontal="center")
    ws.row_dimensions[1].height = 30

    # Encabezados fila 2
    cols_fijas = ["Archivo","Grupo","Formato","Origen","Correo Padre",
                  "Score Final","Categoría","Bloqueo"]
    cols_extra = []
    for cod, cfg in REGLAS.items():
        es_est = cfg["auto"] == "estimado"
        cols_extra.append(f"{cod} – {cfg['descripcion'][:15]}\nDetectado")
        cols_extra.append(f"{cod} Override{'⚠' if es_est else ''}")

    cols_tail = ["Tamaño KB","Hojas","Fórmulas","Fusionadas","Pivot","Table","Contraseña"]
    todas = cols_fijas + cols_extra + cols_tail

    for j, h in enumerate(todas, 1):
        c = ws.cell(row=2, column=j, value=h)
        if j <= len(cols_fijas):
            _hdr(c, "1F4E79")
        elif "Override" in h and "⚠" in h:
            _hdr(c, "7F6000")
        elif "Override" in h:
            _hdr(c, "2E4057")
        else:
            _hdr(c, "2E4057")
    ws.row_dimensions[2].height = 40

    # Datos fila 3+
    for i, r in enumerate(resultados, 3):
        nv = r.get("niveles", {})
        na = r.get("niveles_auto", {})
        _, _, cat, blq = calcular_score(nv)

        fila = [r["archivo"], r["grupo"], r["formato"], r["origen"],
                r["correo_padre"], None, cat, blq or ""]

        col_ov_map = {}  # cod → col_letra del override
        k = 0
        for cod in REGLAS:
            col_det = len(cols_fijas) + k*2 + 1
            col_ov  = len(cols_fijas) + k*2 + 2
            col_ov_map[cod] = get_column_letter(col_ov)
            fila.append(nv.get(cod, ""))
            fila.append("")   # override vacío
            k += 1

        fila += [r.get("tamanio_kb"), r.get("num_hojas"),
                 r.get("total_formulas"), r.get("fusionadas"),
                 "Sí" if r.get("tiene_pivot") else "No",
                 "Sí" if r.get("tiene_table") else "No",
                 "Sí" if r.get("tiene_pwd")   else "No"]

        for j, val in enumerate(fila, 1):
            c = ws.cell(row=i, column=j, value=val)
            c.font      = Font(name="Arial", size=9)
            c.alignment = Alignment(horizontal="center", vertical="center")
            b = Side(style="thin", color="DDDDDD")
            c.border    = Border(left=b, right=b, top=b, bottom=b)

        # Colorear columnas override estimadas en amarillo
        k = 0
        for cod, cfg in REGLAS.items():
            if cfg["auto"] == "estimado":
                col_ov = len(cols_fijas) + k*2 + 2
                ws.cell(i, col_ov).fill = PatternFill("solid", fgColor="FFF2CC")
            k += 1

        # Color de fila (cols fijas) por categoría
        fill_cat = PatternFill("solid", fgColor=COLORES_CAT.get(cat,"FFFFFF"))
        for j in range(1, len(cols_fijas)+1):
            ws.cell(i, j).fill = fill_cat

        # ── Fórmula Excel dinámica para Score Final ───────────────
        partes, techos = [], []
        k = 0
        for cod, cfg in REGLAS.items():
            col_det = get_column_letter(len(cols_fijas) + k*2 + 1)
            col_ov  = get_column_letter(len(cols_fijas) + k*2 + 2)
            max_n   = cfg["max_nivel_normal"]
            peso    = cfg["peso"]

            nivel_expr = f'IF({col_ov}{i}<>"",{col_ov}{i},{col_det}{i})'
            nivel_safe = f'IFERROR({nivel_expr},0)'

            if cfg["bloqueo"]:
                pts = (f'IF({nivel_safe}=10,0,'
                       f'(1-MIN({nivel_safe},{max_n})/{max_n})*{peso}/{PESO_TOTAL_RAW}*100)')
                techos.append(f'IF({nivel_safe}=10,{cfg["techo"]},100)')
            else:
                pts = f'(1-MIN(IFERROR({nivel_expr},0),{max_n})/{max_n})*{peso}/{PESO_TOTAL_RAW}*100'

            partes.append(pts)
            k += 1

        suma = "+".join(partes)
        if techos:
            techo_expr = "MIN(" + ",".join(techos) + ")"
            formula = f"=MIN(ROUND({suma},1),{techo_expr})"
        else:
            formula = f"=ROUND({suma},1)"

        c_score = ws.cell(i, 6, value=formula)
        c_score.font      = Font(name="Arial", size=9, bold=True)
        c_score.alignment = Alignment(horizontal="center")
        b = Side(style="thin", color="DDDDDD")
        c_score.border    = Border(left=b, right=b, top=b, bottom=b)

    # Formato condicional en Score Final
    n = len(resultados) + 2
    ws.conditional_formatting.add(f"F3:F{n}",
        ColorScaleRule(start_type="num", start_value=0,  start_color="FFC7CE",
                       mid_type="num",   mid_value=50,   mid_color="FFEB9C",
                       end_type="num",   end_value=100,  end_color="C6EFCE"))
    _aw(ws, 40)


