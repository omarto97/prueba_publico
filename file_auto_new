def inferir_grupo(ruta, subcarpeta):
    for prefijo, nombre in GRUPOS_CARPETAS.items():
        if subcarpeta.replace("\\","/").startswith(prefijo):
            return nombre
    if subcarpeta and subcarpeta not in (".", ""):
        return subcarpeta.replace("\\","/").split("/")[0].upper()
    base = os.path.splitext(os.path.basename(ruta or "archivo"))[0]
    limpio = re.sub(r"[\s_\-]?\d{4}[-_]?\d{0,2}[-_]?\d{0,2}","",base).strip()
    limpio = re.sub(r"[\s_\-]+","_", limpio).upper()[:30]
    return limpio or "SIN_GRUPO"


