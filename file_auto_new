def _leer_xlsb_pyxlsb(ruta):
    """Lee .xlsb con pyxlsb."""
    import pyxlsb
    hojas = {}
    for nombre_hoja in pyxlsb.open_workbook(ruta).sheets:
        with pyxlsb.open_workbook(ruta) as wb:
            with wb.get_sheet(nombre_hoja) as ws:
                datos = [[c.v for c in row] for row in ws.rows()]
        hojas[nombre_hoja] = pd.DataFrame(datos) if datos else pd.DataFrame()
    return hojas, 0, 0, False, False, None

def _leer_com(ruta):
    """Lee cualquier formato Excel vía win32com (requiere Excel instalado)."""
    try:
        import win32com.client, pythoncom
        pythoncom.CoInitialize()
    except ImportError:
        return {}, 0, 0, False, False, "win32com no disponible"

    xl = None
    try:
        xl  = win32com.client.Dispatch("Excel.Application")
        xl.Visible = False
        xl.DisplayAlerts = False
        wb  = xl.Workbooks.Open(os.path.abspath(ruta), ReadOnly=True, UpdateLinks=False)
        hojas = {}
        fml, fus = 0, 0
        piv, tbl = False, False

        for ws in wb.Worksheets:
            try:
                if ws.PivotTables().Count > 0: piv = True
                if ws.ListObjects.Count > 0:   tbl = True
                usado = ws.UsedRange
                if usado is None:
                    hojas[ws.Name] = pd.DataFrame(); continue
                for cell in usado:
                    if getattr(cell,"HasFormula",False):  fml += 1
                    if getattr(cell,"MergeCells",False):  fus += 1
                vals = usado.Value
                if vals is None:
                    hojas[ws.Name] = pd.DataFrame(); continue
                if not isinstance(vals,(list,tuple)): vals = [[vals]]
                hojas[ws.Name] = pd.DataFrame(list(vals))
            except Exception:
                hojas[ws.Name] = pd.DataFrame()

        wb.Close(False)
        return hojas, fml, fus, piv, tbl, None
    except Exception as e:
        return {}, 0, 0, False, False, str(e)
    finally:
        if xl:
            try: xl.Quit()
            except Exception: pass

def _leer_openpyxl(ruta):
    """
    Lee .xlsx / .xlsm con openpyxl en DOS pasadas optimizadas:

    Pasada 1 — read_only=True, data_only=True  (rápida, solo valores):
        • Extrae DataFrames de cada hoja
        • Cuenta fórmulas aproximadas por % de celdas con None donde se
          esperaría valor (data_only devuelve None en celdas con fórmula
          sin valor cacheado) → estimación suficiente para scoring

    Pasada 2 — read_only=True, data_only=False  (solo metadatos):
        • Detecta PivotTables y Tables leyendo únicamente el XML de relaciones
        • Cuenta merged_cells desde el XML sin cargar valores

    Esto evita cargar el modelo de objetos completo en modo escritura,
    que es lo que hace read_only=False y lo que causaba la lentitud.
    """
    try:
        # ── Pasada 1: valores (read_only, data_only) ──────────────
        wb_vals = openpyxl.load_workbook(ruta, read_only=True, data_only=True)
        hojas   = {}
        fml_aprox = 0

        for ws in wb_vals.worksheets:
            datos = []
            for row in ws.iter_rows(values_only=True):
                # Saltar filas completamente vacías al final (read_only puede
                # incluir filas fantasma más allá del rango real de datos)
                datos.append(list(row))
            # Recortar filas vacías finales
            while datos and all(v is None for v in datos[-1]):
                datos.pop()
            df = pd.DataFrame(datos) if datos else pd.DataFrame()
            hojas[ws.title] = df
            # Estimar fórmulas: celdas None en columnas que deberían tener datos
            # (data_only=True devuelve None donde hay fórmula sin cache)
            if not df.empty:
                fml_aprox += int(df.isnull().sum().sum() * 0.1)  # heurística conservadora

        wb_vals.close()

        # ── Pasada 2: metadatos estructurales (read_only, data_only=False) ──
        # Esta pasada es muy rápida porque solo lee el ZIP interno sin valores
        fus = 0
        piv = False
        tbl = False
        try:
            wb_meta = openpyxl.load_workbook(ruta, read_only=True, data_only=False)
            for ws in wb_meta.worksheets:
                # merged_cells en read_only se expone como atributo
                try:
                    mc = ws.merged_cells
                    if mc:
                        fus += len(list(mc))
                except Exception:
                    pass
                if getattr(ws, "_pivots", None) or getattr(ws, "pivot_tables", None):
                    piv = True
            # Tables y PivotTables: leer desde el ZIP directamente
            # (más fiable que el API de read_only)
            import zipfile
            with zipfile.ZipFile(ruta, "r") as z:
                for name in z.namelist():
                    nl = name.lower()
                    if "pivottable" in nl:  piv = True
                    if "table"      in nl and "pivottable" not in nl: tbl = True
            wb_meta.close()
        except Exception:
            pass  # metadatos opcionales, no bloquear

        return hojas, fml_aprox, fus, piv, tbl, None

    except Exception as e:
        return {}, 0, 0, False, False, str(e)

def _leer_xlrd(ruta):
    """Lee .xls con xlrd (v1.2.0)."""
    try:
        import xlrd
        wb  = xlrd.open_workbook(ruta, formatting_info=True)
        hojas = {}
        fml, fus = 0, 0
        for sh in wb.sheets():
            fus += len(sh.merged_cells())
            datos = []
            for r in range(sh.nrows):
                fila = []
                for c in range(sh.ncols):
                    cell = sh.cell(r,c)
                    if cell.ctype == xlrd.XL_CELL_TEXT and str(cell.value).startswith("="):
                        fml += 1
                    fila.append(cell.value)
                datos.append(fila)
            hojas[sh.name] = pd.DataFrame(datos) if datos else pd.DataFrame()
        return hojas, fml, fus, False, False, None
    except ImportError:
        return {}, 0, 0, False, False, "xlrd no instalado – instala xlrd==1.2.0"
    except Exception as e:
        return {}, 0, 0, False, False, str(e)

def detectar_contrasena(ruta):
    """
    Intenta detectar si el archivo está protegido con contraseña
    usando msoffcrypto-tool. Retorna True/False/None(no disponible).
    """
    try:
        import msoffcrypto
        with open(ruta,"rb") as f:
            office = msoffcrypto.OfficeFile(f)
            return office.is_encrypted()
    except ImportError:
        return None   # librería no disponible
    except Exception:
        return None

def leer_excel(ruta):
    """
    Dispatcher principal. Intenta en orden:
      xlsb → pyxlsb → COM
      xls  → xlrd  → COM
      xlsx/xlsm → openpyxl → COM
    Detecta contraseña y asigna G=0 si corresponde.
    """
    ext = os.path.splitext(ruta)[1].lower()

    # ── Detección de contraseña ANTES de intentar leer ───────────
    tiene_pwd = detectar_contrasena(ruta)

    if ext == ".xlsb":
        try:
            res = _leer_xlsb_pyxlsb(ruta)
            if res[5] is None: return res + (tiene_pwd,)
        except Exception: pass
        res = _leer_com(ruta)
        return res + (tiene_pwd,)

    if ext == ".xls":
        hojas,fml,fus,piv,tbl,err = _leer_xlrd(ruta)
        if err and ("xlrd" in err.lower() or not hojas):
            # Mensaje claro en lugar del error críptico de xlrd
            if "xlsx" in str(err).lower() or "xlrd" in str(err).lower():
                err = (f"xlrd solo soporta .xls (Excel 97-2003). "
                       f"Si este archivo es realmente .xlsx renombrado, "
                       f"cámbiala extensión a .xlsx.")
            hojas,fml,fus,piv,tbl,err2 = _leer_com(ruta)
            if err2: err = f"xlrd: {err} | COM: {err2}"
            else:    err = None
        return hojas, fml, fus, piv, tbl, err, tiene_pwd

    # xlsx / xlsm
    hojas,fml,fus,piv,tbl,err = _leer_openpyxl(ruta)
    if err:
        if es_contrasena_error(err):
            tiene_pwd = True
            return {}, fml, fus, piv, tbl, err, True
        hojas,fml,fus,piv,tbl,err = _leer_com(ruta)
    return hojas, fml, fus, piv, tbl, err, tiene_pwd


